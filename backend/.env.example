# Copy this file to .env and fill in your local values
PORT=5000
CORS_ORIGIN=http://127.0.0.1:5500
DB_ENGINE=sqlite
SQLITE_PATH=portfolio_weirdos.db

# SQLite is active by default using the settings above.
# To switch to MySQL, set DB_ENGINE=mysql and uncomment the MySQL block below.
# DB_ENGINE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=portfolio_weirdos

# Secret and email settings
# SECRET_KEY=your-secret-key
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=your_username
# SMTP_PASSWORD=your_password
# SMTP_FROM=no-reply@portfoleo.local
# SMTP_USE_SSL=true
# SMTP_STARTTLS=false
# ACTIVATION_BASE_URL=http://127.0.0.1:5500
